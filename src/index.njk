---
layout: base.njk
navActive: home
permalink: index.html
pageTitle: "Theatre 17 — Dryden Community Theatre"
pageDescription: "Theatre 17 is Dryden's community theatre group, bringing live performance to Northwestern Ontario since 1972."
---



{% set currentShow = collections.shows | currentShow %}
{% set latestNews  = collections.news  | limit(3) %}

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="container">
    <div class="hero-inner">

      <div class="hero-poster">
        <div class="hero-poster-img">
          {% if currentShow and currentShow.data.poster %}
            <img src="{{ currentShow.data.poster }}" alt="{{ currentShow.data.title }} poster">
          {% elif currentShow %}
            <div class="poster-placeholder">
              <div class="poster-title">{{ currentShow.data.title }}</div>
              <div class="poster-subtitle">Theatre 17 &mdash; {{ currentShow.data.season }} {{ currentShow.data.year }}</div>
            </div>
          {% else %}
            <div class="poster-placeholder">
              <div class="poster-title">Season Announcement<br>Coming Soon</div>
              <div class="poster-subtitle">Theatre 17</div>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="hero-content">
        {% if currentShow %}
          <span class="kicker">{{ currentShow.data.status | statusLabel }}</span>
          <span class="status-badge {{ currentShow.data.status | statusClass }}" style="margin-bottom:1rem;display:inline-flex;">
            {{ currentShow.data.status | statusLabel }}
          </span>
          <h1>{{ currentShow.data.title }}</h1>
          {% if currentShow.data.playwright %}
            <p class="show-playwright">by {{ currentShow.data.playwright }}</p>
          {% endif %}
          {% if currentShow.data.description %}
            <p style="color:var(--ink-mid);font-size:0.98rem;margin-bottom:0;">
              {{ currentShow.data.description | truncate(260) }}
            </p>
          {% endif %}
          <div class="hero-meta">
            {% if currentShow.data.dates %}
            <div class="hero-meta-row">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {{ currentShow.data.dates }}
            </div>
            {% endif %}
            {% if currentShow.data.venue %}
            <div class="hero-meta-row">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {{ currentShow.data.venue }}
            </div>
            {% endif %}
            {% if currentShow.data.show_times %}
            <div class="hero-meta-row">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {{ currentShow.data.show_times }}
            </div>
            {% endif %}
          </div>
          <div class="hero-actions">
            {% if currentShow.data.ticket_url %}
              <a href="{{ currentShow.data.ticket_url }}" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Get Tickets</a>
            {% endif %}
            {% if currentShow.data.status in ["planning", "auditions"] %}
              <a href="{{ currentShow.data.audition_link if currentShow.data.audition_link else '/contact.html' }}"
                 class="btn btn-gold"
                 {% if currentShow.data.audition_link %}target="_blank" rel="noopener noreferrer"{% endif %}>
                Sign Up For Crew/Auditions
              </a>
            {% endif %}
            <a href="/show.html" class="btn btn-outline">Full Details &amp; Cast</a>
          </div>
        {% else %}
          <span class="kicker">Dryden Community Theatre</span>
          <h1>Theatre 17</h1>
          <p>Stay tuned for our next production announcement. In the meantime, browse our show archive or read the latest news.</p>
          <div class="hero-actions">
            <a href="/archive.html" class="btn btn-primary">Show Archive</a>
            <a href="/news.html" class="btn btn-outline">Latest News</a>
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

<!-- ===== NEWS PREVIEW ===== -->
{% if latestNews.length %}
<section class="section" style="background:var(--cream);">
  <div class="container">
    <div class="section-heading">
      <span class="kicker">Latest</span>
      <h2>News &amp; Announcements</h2>
    </div>
    <div class="news-grid">
      {% for post in latestNews %}
      <div class="news-card">
        <span class="news-card-tag">{{ post.data.category | capitalize }}</span>
        <h3><a href="/news.html">{{ post.data.title }}</a></h3>
        {% if post.data.summary %}
          <p>{{ post.data.summary }}</p>
        {% elif post.templateContent %}
          <p>{{ post.templateContent | truncate(140) }}</p>
        {% endif %}
        <div class="news-card-date">{{ post.data.date | formatDate }}</div>
      </div>
      {% endfor %}
    </div>
    <div style="text-align:center;margin-top:2.5rem;">
      <a href="/news.html" class="btn btn-ghost">All News &amp; Announcements</a>
    </div>
  </div>
</section>
{% endif %}

<!-- ===== ABOUT STRIP ===== -->
<div class="about-strip">
  <div class="container">
    <div class="about-strip-inner">
      <div>
        <h2>Dryden's Theatre Community</h2>
        <div class="ornament-full" style="background:rgba(255,255,255,0.15);"></div>
        <p>Theatre 17 has been bringing live performance to Northwestern Ontario for over twenty years. We are a volunteer community theatre dedicated to storytelling, creative expression, and building connections across our community. Everyone is welcome — on stage and in the audience.</p>
      </div>
      <div style="display:flex;flex-direction:column;gap:1rem;flex-shrink:0;">
        <a href="/about.html" class="btn btn-outline" style="border-color:rgba(255,255,255,0.4);color:var(--white);">Our Story</a>
        <a href="/contact.html" class="btn btn-primary" style="background:var(--gold);border-color:var(--gold);">Get Involved</a>
      </div>
    </div>
  </div>
</div>

